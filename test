<!DOCTYPE html>
<html>
<head>
  <title>CSS 基礎</title>
  <style>
    /* 元素選擇器：所有 h1 變藍色 */
    h1 {
      color: blue;
    }
    /* 類別選擇器：紅色文字 */
    .red-text {
      color: red;
      font-size: 24px;
    }
    /* ID 選擇器：綠色背景 */
    #special {
      background-color: green;
      padding: 10px;
    }
  </style>
</head>
<body>
  <h1>歡迎學習 CSS！</h1>
  <p class="red-text">這是紅色大字。</p>
  <div id="special">這是綠底框！</div>
</body>
</html>
